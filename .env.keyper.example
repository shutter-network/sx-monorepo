# Keyper operator environment — used with docker-compose.keyper.yml
# Copy to .env and fill in real values before starting.

# Your keyper ID — assigned by the hub operator (1, 2, or 3)
KEYPER_ID=1

# Port this keyper listens on (must be publicly reachable at this port)
KEYPER_PORT=5001

# Your keyper's Ethereum private key — keep this secret, never share
KEYPER_PRIVATE_KEY=0x...

# The hub operator's coordinator address (public, non-secret) — get this
# from them once, out of band. auto-dkg uses its matching signing key to
# mint and push your bearer tokens automatically via /auth/bootstrap; you
# don't generate or share a token yourself anymore.
COORDINATOR_ADDRESS=0x...

# Public URL of the hub
KEYPER_HUB_URL=https://hub.example.com

# DKG secret retention
KEYPER_DKG_RETENTION_TIME=172800
KEYPER_DKG_PRUNE_INTERVAL_S=3600

# Host-side path for this keyper's encrypted state (bind-mounted to
# /keyper-state). Only needed if you're running more than one instance of
# this compose file on the same machine (e.g. local multi-operator testing) --
# give each instance its own path here, or they'll overwrite each other's
# encrypted state. A real single-operator deployment can leave this unset.
# KEYPER_STATE_DIR_HOST=./keyper-state
