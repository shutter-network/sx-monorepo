# Permanent private voting - Docker stack configuration.
#
# Some values below have a working dev default baked into docker-compose.yml.
# Copy this file to .env and generate your own before running `docker compose
# up`.

# --- Keyper committee signing keys (required -- no default) -----------------
# These three keys define the committee. Their derived Ethereum addresses are
# written to each private proposal's te_keyper_addresses allow-list by the
# auto-dkg service, so the hub accepts the committee's DKG submissions.
# Generate three distinct keys (never reuse one across keypers or environments):
#   python3 -c "import secrets; print('0x' + secrets.token_bytes(32).hex())"
# Production deployments MUST have these held by three independent operators.
KEYPER_PRIVATE_KEY_1=0x...
KEYPER_PRIVATE_KEY_2=0x...
KEYPER_PRIVATE_KEY_3=0x...

# --- Keyper bearer-token auth (empty = single-operator dev mode, no auth) ---
# Both empty by default, matching this file's other dev defaults -- the stack
# runs with no bearer-token auth at all until you set both. Set COORDINATOR_SIGNING_KEY
# and every keyperN's COORDINATOR_ADDRESS together, or a keyper expecting auth
# with no matching coordinator key is locked out permanently. Generate once with:
#   python3 -c "from eth_account import Account; import secrets; k='0x'+secrets.token_bytes(32).hex(); print('key:',k); print('address:',Account.from_key(k).address)"
# auto-dkg then mints and pushes bearer tokens to every keyper automatically via
# COORDINATOR_SIGNING_KEY=0x...
# COORDINATOR_ADDRESS=0x...

# --- Keyper DKG secret retention (shared by all keypers) --------------------
# Time in seconds to keep combined_share on disk after successful decrypt (0 = never prune).
# Default 172800 = 2 days.
# KEYPER_DKG_RETENTION_TIME=172800
# Background prune loop interval in seconds.
# KEYPER_DKG_PRUNE_INTERVAL_S=3600

# --- Sequencer relayer key (required -- no default) --------------------------
SEQ_RELAYER_PK=0x...

# --- Sequencer misc ----------------------------------------------------------
SEQ_AUTH_SECRET=1dfd84a695705665668c260222ded178d1f1d62d251d7bee8148428dac6d0487
WALLETCONNECT_PROJECT_ID=e6454bd61aba40b786e866a69bd4c5c6

# --- Host port mappings ------------------------------------------------------
# Only the host side is configurable; containers always talk to each other on
# the fixed internal ports. Override these if another process already holds a
# default port (e.g. something else on 3000). The UI expects the hub on 3000
# and sequencer on 3001 by default.
# HUB_PORT=3000
# SEQ_PORT=3001
# MYSQL_PORT=3306
# Note: keyper ports are not published to the host. Access via docker exec.
