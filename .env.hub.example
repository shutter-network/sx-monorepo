# Hub operator environment — used with docker-compose.hub.yml
# Copy to .env and fill in real values before starting.

# External keyper URLs (public, reachable from this server)
KEYPER_URLS=https://keyper1.org1.example:5001,https://keyper2.org2.example:5001,https://keyper3.org3.example:5001

# This coordinator's own signing key. Generate once with:
#   python3 -c "import secrets; print('0x'+secrets.token_bytes(32).hex())"
# Share the resulting ADDRESS (not this key) with every keyper operator as
# their COORDINATOR_ADDRESS. auto-dkg then mints and pushes bearer tokens to
# every keyper automatically -- no per-keyper token to collect or rotate by
# hand. See docs/private-voting/keyper-token-bootstrap.md.
COORDINATOR_SIGNING_KEY=0x...

# Sequencer relayer key (signs relayer receipts)
SEQ_RELAYER_PK=0x...

# Sequencer misc
SEQ_AUTH_SECRET=<random_hex_64>
WALLETCONNECT_PROJECT_ID=<your_project_id>

# Threshold config
TE_THRESHOLD_T=1
TE_WEIGHTED_BUDGET=100

# DKG lead time (seconds before proposal start that DKG must complete)
MIN_DKG_LEAD_TIME_S=180
